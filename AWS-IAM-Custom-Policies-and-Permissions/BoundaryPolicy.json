{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BoundaryS3Only",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::testing-lab-07554578",
        "arn:aws:s3:::testing-lab-07554578/*"
      ]
    },
    {
      "Sid": "DenyIAMChanges",
      "Effect": "Deny",
      "Action": "iam:*",
      "Resource": "*"
    }
  ]
}
